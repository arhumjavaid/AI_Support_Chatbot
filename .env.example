# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
# NEVER commit a real key. .env is gitignored.
# ----------------------------------------------------------------------------

# Your Google Gemini API key (free tier works for this demo).
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use. Defaults to gemini-2.0-flash if omitted.
# Other options: gemini-2.0-flash-lite, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Port for the local Express server (frontend dev proxy expects 3001).
PORT=3001
