{
  // TypeScript config for the BACKEND (src/ and api/).
  // The frontend has its own tsconfig in /client.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],

    // --- Strict mode (required by the brief) ---
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    // --- Interop / hygiene ---
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // We run via tsx (no emit). typecheck script uses --noEmit.
    "noEmit": true
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "client", "dist"]
}
